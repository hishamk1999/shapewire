{
  "name": "shapewire-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm --filter shapewire build && pnpm --filter @shapewire/docs build",
    "check": "pnpm --filter shapewire check && pnpm --filter @shapewire/docs typecheck && pnpm --filter @shapewire/docs build",
    "test": "pnpm --filter shapewire test",
    "test:run": "pnpm --filter shapewire test:run",
    "typecheck": "pnpm --filter shapewire typecheck && pnpm --filter @shapewire/docs typecheck",
    "docs:start": "pnpm --filter @shapewire/docs start",
    "docs:build": "pnpm --filter @shapewire/docs build",
    "docs:clear": "pnpm --filter @shapewire/docs clear",
    "docs:serve": "pnpm --filter @shapewire/docs serve",
    "pack:lib": "pnpm --dir packages/shapewire pack"
  },
  "engines": {
    "node": ">=20.0"
  },
  "browserslist": {
    "production": [">0.5%", "not dead", "not op_mini all"],
    "development": ["last 3 chrome version", "last 3 firefox version", "last 5 safari version"]
  },
  "packageManager": "pnpm@10.33.0"
}
