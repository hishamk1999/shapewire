{
  "name": "shapewire",
  "version": "0.1.0-alpha.3",
  "description": "Type-safe pipelines for turning API responses into clean, UI-ready data.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "pnpm clean",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest src",
    "test:run": "vitest run src",
    "typecheck": "tsc -p tsconfig.json",
    "check": "pnpm typecheck && pnpm test:run && pnpm build",
    "prepack": "pnpm build"
  },
  "keywords": [
    "typescript",
    "data-transformation",
    "data-normalization",
    "api",
    "pipeline",
    "type-safe",
    "frontend",
    "object-mapping",
    "immutable",
    "esm"
  ],
  "author": "Hisham Khaled",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hishamk1999/shapewire.git",
    "directory": "packages/shapewire"
  },
  "bugs": {
    "url": "https://github.com/hishamk1999/shapewire/issues"
  },
  "homepage": "https://github.com/hishamk1999/shapewire#readme",
  "engines": {
    "node": ">=20.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
