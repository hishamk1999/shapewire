{
  "name": "shapewire",
  "version": "1.0.0",
  "description": "Composable, type-safe API-to-UI data transforms",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "pnpm clean",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest src",
    "test:run": "vitest run src",
    "typecheck": "tsc -p tsconfig.json",
    "check": "pnpm typecheck && pnpm test:run && pnpm build",
    "prepack": "pnpm build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
